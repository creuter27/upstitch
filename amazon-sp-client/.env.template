# Amazon Selling Partner API credentials
# Copy this file to .env and fill in real values.
# Obtain from: Seller Central → Apps & Services → Develop Apps → your app

# LWA (Login with Amazon) — from your SP-API app registration
AMAZON_LWA_APP_ID=
AMAZON_LWA_CLIENT_SECRET=

# Refresh token — obtained after authorizing your app in Seller Central
AMAZON_REFRESH_TOKEN=

# AWS IAM credentials for the SP-API role
AMAZON_AWS_ACCESS_KEY=
AMAZON_AWS_SECRET_KEY=
AMAZON_ROLE_ARN=fff

# Marketplace ID (default: Amazon.de = A1PA6795UKMFR9)
# Other EU: FR=A13V1IB3VIYZZH, IT=APJ6JRA9NG5V4, ES=A1RKKUPIHCS9HS, UK=A1F83G7Y2K3M5L
AMAZON_MARKETPLACE_ID=A1PA6795UKMFR9
